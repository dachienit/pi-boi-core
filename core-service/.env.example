# Proxy configuration (local only - not needed on BTP)
# PROX=http://127.0.0.1:3128
# AGENT_USER=your_username
# AGENT_PWD=your_password

# LLM configuration
# Provider name - must match a known provider in @mariozechner/pi-ai (e.g. openai, anthropic, openrouter, groq)
LLM_PROVIDER=openai

# Model ID for the chosen provider
#LLM_MODEL=gpt-4o-mini
LLM_MODEL=gpt-5-nano-2025-08-07

# Custom API base URL - use this for OpenAI-compatible endpoints:
#   Ollama:     http://localhost:11434/v1
#   LM Studio:  http://localhost:1234/v1
#   vLLM:       http://localhost:8000/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   Bosch GenAI: https://aoai-farm.bosch-temp.com/api/openai/deployments/<model>
# LLM_BASE_URL=https://aoai-farm.bosch-temp.com/api/openai/deployments/gpt-5-nano-2025-08-07

# API key - alternative to storing in ~/.pi/mom/auth.json
# LLM_API_KEY=sk-...

# Custom auth header name (for non-standard APIs like Bosch GenAI Platform)
# LLM_API_VERSION=2025-04-01-preview
# LLM_AUTH_HEADER=genaiplatform-farm-subscription-key

# Core service port (default: 3030)
# PORT=3030
